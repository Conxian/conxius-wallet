{
  "name": "conxius-wallet",
  "private": true,
  "version": "1.9.5",
  "packageManager": "pnpm@11.13.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm run check:typescript-compat && tsc && vite build",
    "preview": "vite preview",
    "android:build": "pnpm run build && pnpm cap sync && pnpm cap open android",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "bench:silent-payments": "node scripts/bench-silent-payments.mjs",
    "prepare": "husky",
    "lint": "pnpm run check:typescript-compat && eslint .",
    "typecheck": "pnpm run check:typescript-compat && tsc --noEmit",
    "verify": "bash scripts/ci/verify_local.sh",
    "check:typescript-compat": "node scripts/ci/check_typescript_compatibility.mjs",
    "check:release-version": "node scripts/ci/check_release_version.mjs",
    "check:workflow-pins": "python3 scripts/ci/check_workflow_pins.py",
    "check:android-security": "bash scripts/ci/validate_android_security.sh"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/browser": "^8.0.4",
    "@capacitor/core": "^8.4.2",
    "@capacitor/local-notifications": "^8.2.1",
    "@fontsource/inter": "^5.3.0",
    "@fontsource/jetbrains-mono": "^5.3.0",
    "@google/genai": "^2.12.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@stacks/auth": "^7.5.0",
    "@stacks/common": "^7.5.0",
    "@stacks/network": "^7.5.0",
    "@stacks/transactions": "^7.5.0",
    "@testing-library/dom": "^10.4.1",
    "@web5/api": "^0.12.0",
    "@wormhole-foundation/sdk": "^6.1.3",
    "@wormhole-foundation/sdk-evm": "^6.1.3",
    "@wormhole-foundation/sdk-solana": "^6.1.3",
    "@zxing/browser": "^0.2.1",
    "@zxing/library": "^0.23.0",
    "algosdk": "^3.6.0",
    "bech32": "^2.0.0",
    "bip32": "^5.0.1",
    "bip39": "^3.1.0",
    "bitcoinjs-lib": "^7.0.1",
    "buffer": "^6.0.3",
    "ecpair": "^3.0.1",
    "generator-function": "^2.0.1",
    "is-generator-function": "^1.1.2",
    "light-bolt11-decoder": "^3.0.0",
    "liquidjs-lib": "^6.0.2-liquid.38",
    "lucide-react": "^1.25.0",
    "node-fetch": "^3.3.2",
    "payjoin-client": "^1.0.1",
    "qrcode": "^1.5.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.10.0",
    "tiny-secp256k1": "^2.2.4",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0"
  },
  "devDependencies": {
    "@aptos-labs/ts-sdk": "^7.2.0",
    "@capacitor/cli": "^8.4.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@solana/web3.js": "^1.98.4",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/ui": "^4.1.10",
    "@wormhole-foundation/sdk-definitions-ntt": "^7.2.0",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "postcss": "^8.5.21",
    "semver": "7.8.5",
    "tailwindcss": "^4.3.3",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "vitest related --run"
    ]
  }
}
